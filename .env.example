# ===========================================
# htg-rates — Configuration
# Copiez ce fichier vers .env à la racine de votre projet
# ===========================================

# --- Serveur ---
PORT=3000

# --- Source BRH ---
BRH_URL=https://www.brh.ht/taux-du-jour/
BRH_TIMEOUT_MS=10000
BRH_RETRIES=3

# --- Cache mémoire ---
CACHE_TTL_MS=900000
SERVE_STALE_ON_ERROR=true

# --- Historique JSON (un fichier par année) ---
SAVE_HISTORY=true
HISTORY_DATA_DIR=./data/history

# --- Sécurité / API ---
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
